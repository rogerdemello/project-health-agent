# --- LLM: NVIDIA NIM (OpenAI-compatible endpoint) ---
# Executive reasoning/narration is generated by an LLM (scoring is always
# deterministic and never uses the LLM). Get a free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# Optional overrides (sensible defaults baked in):
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=meta/llama-3.3-70b-instruct

# Alternative: use OpenAI directly instead of NVIDIA NIM.
# Leave NVIDIA_API_KEY blank and set these instead:
# OPENAI_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Output directory for reports
OUTPUT_DIR=outputs
